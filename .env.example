# Base de datos PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/gym_db?schema=public"

# Autenticación JWT
JWT_SECRET="cambia-esto-por-un-secreto-seguro-minimo-32-chars"
JWT_EXPIRES_IN="7d"

# Auth.js v5 — requerido (mínimo 32 caracteres)
AUTH_SECRET="cambia-esto-por-un-secreto-seguro-minimo-32-chars"

# Next.js (legado)
NEXTAUTH_SECRET="cambia-esto-tambien"
NEXTAUTH_URL="http://localhost:3000"

# Entorno
NODE_ENV="development"
